<?xml version="1.0" encoding="UTF-8"?>
<openbox_config xmlns="http://openbox.org/3.4/rc">
  <applications>
    <!-- Force every window fullscreen with no decorations.
         Ensures Firefox is fullscreen from the moment it maps. -->
    <application class="*">
      <fullscreen>yes</fullscreen>
      <decor>no</decor>
    </application>
  </applications>
</openbox_config>
