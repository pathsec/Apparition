# ══════════════════════════════════════════════════════════════════════
# Apparition — Environment Variables
# Copy this file to .env and fill in all required (*) values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────
PORT=3000

# * PUBLIC base URL of this control server (shown to users in join links and emails).
# Set to your public domain.
CONTROL_HOST=https://manager.example.com

# Internal URL containers use to call back to this server (submit/complete/profile upload).
# Must be reachable from inside Docker containers. On Linux use host.docker.internal.
CONTAINER_HOST=http://host.docker.internal:3000

# * Hostname/IP that end-users use to reach NoVNC container ports.
# If the control server and containers are behind an nginx reverse proxy,
# set this to your public hostname and configure nginx to forward ports 6900-6999.
NOVNC_HOST=host.docker.internal

# ── Security ──────────────────────────────────────────────────────────
# * Long random strings — generate with: openssl rand -hex 64
SESSION_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# Set to true only when serving over HTTPS — otherwise session cookies won't be sent
COOKIE_SECURE=false
JWT_SECRET=REPLACE_WITH_DIFFERENT_LONG_RANDOM_STRING

# ── Database ──────────────────────────────────────────────────────────
DB_PATH=/data/app.db   # inside the Docker volume; change for host-path mounts

# ── Docker / Container settings ───────────────────────────────────────
NOVNC_IMAGE=novnc-kiosk

# Port pool allocated to NoVNC containers on the host.
# Each concurrent session consumes one port. Ensure these are open in your firewall.
NOVNC_PORT_START=6900
NOVNC_PORT_END=6999

# Docker network containers are attached to.
# If the control server and containers need to communicate, put them on the same
# named network rather than the default bridge.
CONTAINER_NETWORK=bridge

# Resource limits per container (bytes / nanocpus)
CONTAINER_MEMORY_LIMIT=1073741824   # 1 GB
CONTAINER_CPU_LIMIT=1000000000      # 1 CPU

# How often the cleanup job checks for expired sessions (milliseconds)
CLEANUP_INTERVAL_MS=60000

# ── SMTP / Email ──────────────────────────────────────────────────────
# These override any values saved via the Settings UI.
# For Mailjet: HOST=in-v3.mailjet.com, USER=<API key>, PASS=<Secret key>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false   # set to true for port 465 / SMTPS
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=Apparition
